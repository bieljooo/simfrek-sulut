* text=auto eol=lf

*.blade.php diff=html linguist-language=Blade
*.css diff=css
*.html diff=html
*.md diff=markdown
*.php diff=php

bootstrap/cache/** linguist-generated=true
public/build/** linguist-generated=true
public/hot linguist-generated=true
storage/framework/** linguist-generated=true
storage/logs/** linguist-generated=true
vendor/** linguist-vendored=true
node_modules/** linguist-vendored=true
composer.lock linguist-generated=true
package-lock.json linguist-generated=true
yarn.lock linguist-generated=true
pnpm-lock.yaml linguist-generated=true

/.github export-ignore
CHANGELOG.md export-ignore
.styleci.yml export-ignore
